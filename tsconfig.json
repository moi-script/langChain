{
  "compilerOptions": {
    "module": "commonjs",            // Changed from NodeNext
    "moduleResolution": "Node",      // Ensures it looks into node_modules correctly
    "target": "ES2022",
    "esModuleInterop": true,         // Vital for importing JS libraries into TS
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  }
}